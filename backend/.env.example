# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.
#
# Used by:
#   - braintrust eval CLI (auto-loaded)
#   - scripts/create_braintrust_dataset.py (loaded via python-dotenv)
#   - uv run pytest evals/ -m agent (loaded via conftest.py)

# ── Braintrust ───────────────────────────────────────────────────────────────
BRAINTRUST_API_KEY=

# ── AWS (Bedrock InvokeModel access required) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── SST resource stubs ────────────────────────────────────────────────────────
# Evals mock all DynamoDB and Knowledge Base I/O — these values are never used
# for real API calls. They exist only so config.py can import without a live
# SST deployment.
SST_RESOURCE_Bookings={"name":"eval-stub"}
SST_RESOURCE_RestaurantKB={"id":"eval-stub"}
SST_RESOURCE_AgentSessions={"name":"eval-sessions"}
